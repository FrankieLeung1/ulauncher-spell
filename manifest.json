{
    "api_version": "3",
    "name": "Spell",
    "authors": "Lohen Yumnam",
    "icon": "images/icon.png",
    "input_debounce": 0.05,
    "triggers": {
        "keyword": {
            "name": "Spell",
            "description": "Spelling assistance and word lookup",
            "default_keyword": "spell"
        }
    },
    "preferences": {
        "matching": {
            "type": "select",
            "name": "Matching method",
            "description": "Matching method. 'symspell' is ultra-fast (3000x faster), 'fuzzy' is balanced, 'regex' is prefix-only",
            "default_value": "symspell",
            "options": [
                {"value": "symspell", "text": "SymSpell (ultra-fast)"},
                {"value": "fuzzy", "text": "Fuzzy (balanced)"},
                {"value": "regex", "text": "Regex (prefix-only)"}
            ]
        },
        "vocabulary": {
            "type": "text",
            "name": "Active vocabulary",
            "description": "Active vocabularies: comma-delimited text. Supported: english_uk, english, deutsch, espanol, francais, italiano, nederlands, norsk",
            "default_value": "english_uk, english"
        }
    }
}
